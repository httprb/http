module HTTP
  class CookieJar
    include Enumerable[untyped]

    def initialize: () -> void
    def parse: (String, untyped) -> void
    def add: (untyped) -> void
    def delete: (untyped) -> void
    def each: () { (untyped) -> void } -> void
           | () -> Enumerator[untyped, void]
    def empty?: () -> bool
    def cookies: () -> Array[untyped]
  end

  class Cookie
    attr_reader name: String
    attr_reader value: String
    attr_reader cookie_value: String

    def self.parse: (String, untyped) -> Array[HTTP::Cookie]
    def self.cookie_value_to_hash: (String) -> Hash[String, String]
    def initialize: (String, String, **untyped) -> void
  end

  module FormData
    class Multipart
      def content_type: () -> String
    end

    class Urlencoded
      def content_type: () -> String
    end

    def self.create: (untyped) -> (Multipart | Urlencoded)
  end
end

